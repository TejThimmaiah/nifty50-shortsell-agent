# Nifty50ShortSellAgent — Nifty 50 Intraday Short Selling Agent
# Copy to .env and fill in values. NEVER commit .env to Git.

# ── MANDATE (never change) ────────────────────────────────────────────────────
# This agent short-sells Nifty 50 stocks intraday ONLY.
# Direction: SHORT_ONLY | Universe: NIFTY50 | Orders: MIS | Exchange: NSE

# ── ZERODHA (order API — FREE for individuals in 2026) ───────────────────────
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=         # refreshed daily by GCP cron at 8 AM IST
KITE_USER_ID=your_zerodha_user_id
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_totp_base32_secret

# ── FREE LLM: Groq (14,400 req/day — no credit card) ────────────────────────
# Sign up: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ── FREE LLM fallback: Google Gemini 1.5 Flash ───────────────────────────────
# Sign up: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── FREE: Telegram bot ───────────────────────────────────────────────────────
# Create bot: https://t.me/BotFather → /newbot
# Get chat ID: message your bot → curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id_number

# ── FREE: Cloudflare webhook + Pages ─────────────────────────────────────────
CLOUDFLARE_WEBHOOK_URL=https://your-worker.your-subdomain.workers.dev
CLOUDFLARE_WEBHOOK_SECRET=choose_a_random_string

# ── GitHub (for GCP health ping) ─────────────────────────────────────────────
GITHUB_TOKEN=your_personal_access_token
GITHUB_REPO=yourusername/nifty50-shortsell-agent

# ── TRADING MODE ──────────────────────────────────────────────────────────────
PAPER_TRADE=true   # Change to false ONLY after 2 weeks profitable paper trading

# ── LOG LEVEL ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE (Rs 0/month total)
# ─────────────────────────────────────────────────────────────────────────────
#
# GitHub Actions (all trading compute — public repo = unlimited free minutes):
#   Make repo public → add all secrets above → enable trading_session.yml
#   Runner: 2 vCPU + 7 GB RAM | Schedule: 9:20 AM–3:10 PM IST Mon–Fri
#
# GCP e2-micro Always Free (off-hours tasks only):
#   Create instance in us-central1, machine type MUST be e2-micro
#   Run: bash deploy/setup_gcp_emicro.sh
#   Handles: 8 AM Kite token refresh, health ping, DB backup
#
# Cloudflare Workers + Pages (webhook + dashboard):
#   cd cloudflare && wrangler deploy webhook.js
#   Connect dashboard/ to Cloudflare Pages via GitHub
#
# COST SUMMARY:
#   Everything        : Rs 0/month
#   Zerodha Kite API  : Rs 0/month (Personal plan, 2026)
#   Market data       : Rs 0/month (NSE public API + yfinance)
#   TOTAL             : Rs 0/month
